---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="section cta-section">
  <div class="container">
    <div class="cta-box">
      <div class="cta-glow"></div>
      <div class="cta-content">
        <h2>{t('cta.title')}<br /><span class="accent-blue">{t('cta.title_accent')}</span></h2>
        <p>{t('cta.desc')}</p>
        <div class="cta-actions">
          <a href={`https://docs.keel-go.dev/${lang}/`} class="btn-primary">
            {t('cta.btn_start')}
          </a>
          <a href="https://github.com/slice-soft/ss-keel-core" target="_blank" rel="noopener noreferrer" class="btn-secondary">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            {t('cta.btn_github')}
          </a>
          <a href="https://github.com/slice-soft/ss-community" target="_blank" rel="noopener noreferrer" class="btn-secondary">
            {t('cta.btn_community')}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section { padding-bottom: 96px; }

  .cta-box {
    position: relative;
    border: 1px solid rgba(59, 130, 246, 0.25);
    border-radius: var(--radius-lg, 12px);
    padding: 64px 48px;
    text-align: center;
    overflow: hidden;
    background: var(--ss-card);
    box-shadow: var(--shadows-card);
  }

  .cta-glow {
    position: absolute;
    top: -80px;
    left: 50%;
    transform: translateX(-50%);
    width: 500px;
    height: 300px;
    background: radial-gradient(ellipse at center, rgba(59, 130, 246, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-content { position: relative; z-index: 1; }

  h2 {
    font-size: clamp(26px, 4vw, 42px);
    font-weight: var(--text-weights-bold, 700);
    letter-spacing: -0.025em;
    line-height: var(--text-line-heights-tight, 1.2);
    margin-bottom: var(--dimensions-4, 16px);
    color: var(--ss-text);
  }

  p {
    font-size: var(--text-sizes-base, 16px);
    color: var(--ss-muted);
    max-width: 500px;
    margin: 0 auto var(--dimensions-8, 32px);
    line-height: var(--text-line-heights-relaxed, 1.625);
  }

  .cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--dimensions-3, 12px);
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 12px 28px;
    border-radius: var(--radius-base, 8px);
    font-size: var(--text-sizes-base, 16px);
    font-weight: var(--text-weights-semibold, 600);
    text-decoration: none;
    background: var(--color-primary);
    color: #fff;
    transition: background var(--transitions-durations-short, 100ms);
  }

  .btn-primary:hover { background: var(--color-primary-hover); }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 12px 20px;
    border-radius: var(--radius-base, 8px);
    font-size: var(--text-sizes-base, 16px);
    font-weight: var(--text-weights-medium, 500);
    text-decoration: none;
    border: 1px solid var(--ss-border);
    color: var(--ss-text);
    background: transparent;
    transition: all var(--transitions-durations-short, 100ms);
  }

  .btn-secondary:hover {
    border-color: rgba(59, 130, 246, 0.4);
    background: rgba(59, 130, 246, 0.06);
  }

  @media (max-width: 600px) {
    .cta-box { padding: 40px 24px; }
  }
</style>
