---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { addons, categoryColors } from "../data/addons";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="addons" class="section section-alt">
  <div class="container">
    <h2 class="section-title">
      {t('addons.section_title')} <span class="accent-blue">{t('addons.section_title_accent')}</span>
    </h2>
    <p class="section-desc">{t('addons.section_desc')}</p>

    <div class="grid">
      {addons.map(addon => (
        <div class="card">
          <div class="card-top">
            <span class={`cat cat-${categoryColors[addon.category]}`}>{addon.category}</span>
            {addon.live
              ? <span class="badge-live">{t('addons.badge_live')}</span>
              : <span class="badge-soon">{t('addons.badge_soon')}</span>
            }
          </div>
          <div class="addon-name">{addon.name}</div>
          <p class="addon-desc">{t(`addons.${addon.key}.desc` as any)}</p>
          {addon.live && addon.slug && (
            <a href={`https://docs.keel-go.dev/${lang}${addon.slug}`} 
               target="_blank" 
               rel="noopener noreferrer" 
               class="btn-docs">
              {t('addons.btn_docs')}
            </a>
          )}
        </div>
      ))}
    </div>

    <p class="addon-note">
      {t('addons.note')}
      <a href="https://docs.keel-go.dev" target="_blank" rel="noopener noreferrer">{t('addons.note_link')}</a>
    </p>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--dimensions-4, 16px);
    margin-bottom: var(--dimensions-8, 32px);
  }

  .card {
    background: var(--ss-bg);
    border: 1px solid var(--ss-border);
    border-radius: var(--radius-lg, 12px);
    padding: var(--dimensions-4, 16px);
    box-shadow: var(--shadows-card);
    transition: border-color var(--transitions-durations-medium, 300ms);
    display: flex;
    flex-direction: column;
    gap: var(--dimensions-2, 8px);
  }

  .card:hover { border-color: rgba(59, 130, 246, 0.25); }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 6px;
  }

  .cat {
    font-size: 11px;
    font-weight: var(--text-weights-medium, 500);
    padding: 2px 8px;
    border-radius: var(--radius-full, 9999px);
    border: 1px solid;
  }

  .cat-blue   { color: #60a5fa; background: rgba(59,130,246,0.1); border-color: rgba(59,130,246,0.25); }
  .cat-red    { color: #f87171; background: rgba(248,113,113,0.1); border-color: rgba(248,113,113,0.25); }
  .cat-purple { color: #c084fc; background: rgba(192,132,252,0.1); border-color: rgba(192,132,252,0.25); }
  .cat-orange { color: #fb923c; background: rgba(251,146,60,0.1); border-color: rgba(251,146,60,0.25); }
  .cat-cyan   { color: var(--color-accent); background: rgba(34,211,238,0.1); border-color: rgba(34,211,238,0.25); }
  .cat-yellow { color: #facc15; background: rgba(250,204,21,0.1); border-color: rgba(250,204,21,0.25); }
  .cat-green  { color: #4ade80; background: rgba(74,222,128,0.1); border-color: rgba(74,222,128,0.25); }
  .cat-pink   { color: #f472b6; background: rgba(244,114,182,0.1); border-color: rgba(244,114,182,0.25); }
  .cat-teal   { color: #2dd4bf; background: rgba(45,212,191,0.1); border-color: rgba(45,212,191,0.25); }

  .badge-live {
    font-size: 11px;
    font-weight: var(--text-weights-medium, 500);
    color: #22c55e;
    background: rgba(34,197,94,0.1);
    border: 1px solid rgba(34,197,94,0.25);
    padding: 2px 8px;
    border-radius: var(--radius-full, 9999px);
  }

  .badge-soon {
    font-size: 11px;
    font-weight: var(--text-weights-medium, 500);
    color: var(--ss-muted);
    background: rgba(148,163,184,0.08);
    border: 1px solid var(--ss-border);
    padding: 2px 8px;
    border-radius: var(--radius-full, 9999px);
  }

  .addon-name {
    font-size: 13px;
    font-weight: var(--text-weights-semibold, 600);
    font-family: var(--text-fonts-mono, ui-monospace, monospace);
    color: var(--ss-text);
  }

  .addon-desc {
    font-size: 12px;
    color: var(--ss-muted);
    line-height: var(--text-line-heights-relaxed, 1.625);
    flex: 1;
  }

  .btn-docs {
    display: inline-block;
    font-size: 12px;
    font-weight: var(--text-weights-medium, 500);
    color: var(--color-primary);
    text-decoration: none;
    padding: 6px 12px;
    border: 1px solid rgba(59, 130, 246, 0.25);
    border-radius: var(--radius-md, 8px);
    background: rgba(59, 130, 246, 0.05);
    transition: all var(--transitions-durations-fast, 200ms);
    text-align: center;
    margin-top: 4px;
  }

  .btn-docs:hover {
    background: rgba(59, 130, 246, 0.1);
    border-color: rgba(59, 130, 246, 0.4);
    text-decoration: none;
  }

  .addon-note {
    text-align: center;
    font-size: var(--text-sizes-sm, 14px);
    color: var(--ss-muted);
  }

  .addon-note a {
    color: var(--color-primary);
    text-decoration: none;
    margin-left: 4px;
  }

  .addon-note a:hover { text-decoration: underline; }

  @media (max-width: 900px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .grid { grid-template-columns: 1fr; } }
</style>
