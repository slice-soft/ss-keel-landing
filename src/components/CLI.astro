---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { cliCommands, cliFeatureKeys } from "../data/cli";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="cli" class="section">
  <div class="container cli-layout">

    <div class="cli-text">
      <div class="eyebrow">{t('cli.eyebrow')}</div>
      <h2>{t('cli.title')}<br /><span class="accent-blue">{t('cli.title_accent')}</span></h2>
      <p class="cli-desc">{t('cli.desc')}</p>

      <ul class="cli-feature-list">
        {cliFeatureKeys.map((key, i) => (
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            {i === 2
              ? <span>{t(key as any)} (<code>keel run</code>)</span>
              : i === 3
              ? <span>{t(key as any)} <code>keel upgrade</code></span>
              : t(key as any)
            }
          </li>
        ))}
      </ul>

      <a href="https://docs.keel-go.dev" class="btn-cli">{t('cli.cta')}</a>
    </div>

    <div class="terminal">
      <div class="terminal-bar">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
        <span class="terminal-title">terminal</span>
      </div>
      <div class="terminal-body">
        {cliCommands.map((block, bi) => (
          <>
            {bi > 0 && <br />}
            <div class="t-line">
              <span class="prompt">$</span>
              <span class="cmd">{block.cmd}</span>
            </div>
            {block.outputKeys.map(key => (
              <div class={`t-output${block.success ? ' success' : ''}`}>
                {t(key as any)}
              </div>
            ))}
          </>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .cli-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--dimensions-16, 64px);
    align-items: center;
  }

  .eyebrow {
    font-size: var(--text-sizes-sm, 14px);
    font-weight: var(--text-weights-medium, 500);
    color: var(--color-primary);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: var(--dimensions-4, 16px);
  }

  h2 {
    font-size: clamp(28px, 4vw, 42px);
    font-weight: var(--text-weights-bold, 700);
    letter-spacing: -0.025em;
    line-height: var(--text-line-heights-tight, 1.2);
    margin-bottom: var(--dimensions-5, 20px);
    color: var(--ss-text);
  }

  .cli-desc {
    font-size: var(--text-sizes-base, 16px);
    color: var(--ss-muted);
    line-height: var(--text-line-heights-relaxed, 1.625);
    margin-bottom: var(--dimensions-6, 24px);
  }

  .cli-feature-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--dimensions-3, 12px);
    margin-bottom: var(--dimensions-8, 32px);
  }

  .cli-feature-list li {
    display: flex;
    align-items: center;
    gap: var(--dimensions-2, 8px);
    font-size: var(--text-sizes-sm, 14px);
    color: var(--ss-muted);
  }

  .cli-feature-list svg { color: #22c55e; flex-shrink: 0; }

  .cli-feature-list code {
    font-family: var(--text-fonts-mono, ui-monospace, monospace);
    font-size: 12px;
    background: var(--ss-card);
    border: 1px solid var(--ss-border);
    padding: 1px 6px;
    border-radius: var(--radius-sm, 4px);
  }

  .btn-cli {
    display: inline-flex;
    align-items: center;
    padding: 10px 20px;
    border-radius: var(--radius-base, 8px);
    font-size: var(--text-sizes-sm, 14px);
    font-weight: var(--text-weights-medium, 500);
    text-decoration: none;
    border: 1px solid var(--color-primary);
    color: var(--color-primary);
    transition: all var(--transitions-durations-short, 100ms);
  }

  .btn-cli:hover {
    background: rgba(59, 130, 246, 0.08);
  }

  /* ── Terminal ── */
  .terminal {
    background: #0d1117;
    border: 1px solid var(--ss-border);
    border-radius: var(--radius-lg, 12px);
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  :global([data-theme="light"]) .terminal {
    border-color: rgba(0,0,0,0.12);
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    background: rgba(255,255,255,0.02);
  }

  .dot { width: 10px; height: 10px; border-radius: 50%; }
  .dot.red    { background: #ff5f57; }
  .dot.yellow { background: #febc2e; }
  .dot.green  { background: #28c840; }

  .terminal-title {
    margin-left: 6px;
    font-size: 12px;
    color: #94a3b8;
    font-family: var(--text-fonts-mono, ui-monospace, monospace);
  }

  .terminal-body {
    padding: 20px 24px;
    font-family: var(--text-fonts-mono, ui-monospace, monospace);
    font-size: 13px;
    line-height: 1.8;
  }

  .t-line {
    display: flex;
    gap: 10px;
  }

  .prompt { color: #4ade80; user-select: none; }
  .cmd    { color: #f1f5f9; }

  .t-output {
    color: #64748b;
    padding-left: 20px;
  }

  .t-output.success { color: #4ade80; }

  @media (max-width: 900px) {
    .cli-layout { grid-template-columns: 1fr; }
    .terminal { display: none; }
  }
</style>
