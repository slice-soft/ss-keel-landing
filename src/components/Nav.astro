---
import { getLangFromUrl, useTranslations, LANGUAGES_KEYS, getLocalizedPathname } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<header class="nav">
  <div class="container nav-inner">
    <a href={`/${lang}/`} class="logo">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
        <rect width="28" height="28" rx="6" fill="var(--color-primary)"/>
        <path d="M7 8h3v5.5L15.5 8H19l-6 6.5L19.5 21H16l-6-6.5V21H7V8z" fill="white"/>
      </svg>
      <span>Keel</span>
    </a>

    <nav class="nav-links">
      <a href="#features">{t('nav.features')}</a>
      <a href="#architecture">{t('nav.architecture')}</a>
      <a href="#addons">{t('nav.addons')}</a>
      <a href="#cli">{t('nav.cli')}</a>
      <a href="https://github.com/slice-soft/ss-keel-core" target="_blank" rel="noopener noreferrer">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        GitHub
      </a>
    </nav>

    <div class="nav-actions">
      <a href={`https://docs.keel-go.dev/${lang}/`} class="btn-docs">{t('nav.docs')}</a>

      <div class="lang-switcher" role="group" aria-label="Language">
        {LANGUAGES_KEYS.map(l => (
          <a
            href={getLocalizedPathname(Astro.url.pathname, l)}
            class:list={['lang-btn', { 'lang-btn--active': l === lang }]}
            aria-current={l === lang ? 'page' : undefined}
          >
            {l.toUpperCase()}
          </a>
        ))}
      </div>

      <button class="theme-toggle is-dark" id="theme-toggle" aria-label={t('nav.toggle_theme')}>
        <svg class="icon-sun" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"/>
          <line x1="12" y1="2" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="icon-moon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('theme-toggle')
  const html   = document.documentElement
  function sync() {
    const dark = html.dataset.theme !== 'light'
    toggle?.classList.toggle('is-dark', dark)
  }
  toggle?.addEventListener('click', () => {
    const next = html.dataset.theme === 'light' ? 'dark' : 'light'
    html.dataset.theme = next
    localStorage.setItem('keel-theme', next)
    sync()
  })
  sync()
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(13, 17, 23, 0.85);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--ss-border);
    transition: background-color var(--transitions-durations-medium, 300ms);
  }

  :global([data-theme="light"]) .nav {
    background: rgba(255, 255, 255, 0.9);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    height: 64px;
    gap: var(--dimensions-8, 32px);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--dimensions-2, 8px);
    text-decoration: none;
    color: var(--ss-text);
    font-weight: var(--text-weights-bold, 700);
    font-size: var(--text-sizes-lg, 18px);
    flex-shrink: 0;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--dimensions-6, 24px);
    flex: 1;
  }

  .nav-links a {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: var(--ss-muted);
    text-decoration: none;
    font-size: var(--text-sizes-sm, 14px);
    transition: color var(--transitions-durations-short, 100ms);
  }

  .nav-links a:hover { color: var(--ss-text); }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--dimensions-3, 12px);
    margin-left: auto;
    flex-shrink: 0;
  }

  .btn-docs {
    display: inline-flex;
    align-items: center;
    padding: 7px 16px;
    border-radius: var(--radius-base, 8px);
    font-size: var(--text-sizes-sm, 14px);
    font-weight: var(--text-weights-medium, 500);
    text-decoration: none;
    background: var(--color-primary);
    color: #fff;
    transition: background var(--transitions-durations-short, 100ms);
  }

  .btn-docs:hover { background: var(--color-primary-hover); }

  .lang-switcher {
    display: flex;
    align-items: center;
    gap: 2px;
    background: var(--ss-card);
    border: 1px solid var(--ss-border);
    border-radius: var(--radius-base, 8px);
    padding: 3px;
  }

  .lang-btn {
    font-size: 12px;
    font-weight: var(--text-weights-semibold, 600);
    color: var(--ss-muted);
    text-decoration: none;
    padding: 3px 8px;
    border-radius: 5px;
    letter-spacing: 0.04em;
    transition: all var(--transitions-durations-short, 100ms);
  }

  .lang-btn:hover { color: var(--ss-text); }

  .lang-btn--active {
    background: var(--color-primary);
    color: #fff;
  }

  .lang-btn--active:hover { color: #fff; }

  .theme-toggle {
    all: unset;
    cursor: pointer;
    color: var(--ss-muted);
    display: flex;
    align-items: center;
    padding: 4px;
    border-radius: var(--radius-sm, 4px);
    transition: color var(--transitions-durations-short, 100ms);
  }

  .theme-toggle:hover { color: var(--ss-text); }

  .icon-sun, .icon-moon { display: none; }
  .theme-toggle.is-dark .icon-sun  { display: block; }
  .theme-toggle:not(.is-dark) .icon-moon { display: block; }

  @media (max-width: 768px) {
    .nav-links { display: none; }
  }
</style>
