---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { featureKeys, featureIcons } from "../data/features";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="features" class="section section-alt">
  <div class="container">
    <h2 class="section-title">
      {t('features.section_title')} <span class="accent-blue">{t('features.section_title_accent')}</span>
    </h2>
    <p class="section-desc">{t('features.section_desc')}</p>

    <div class="grid">
      {featureKeys.map(key => (
        <div class="card">
          <div class="icon" set:html={featureIcons[key]} />
          <h3>{t(`features.${key}.title` as any)}</h3>
          <p>{t(`features.${key}.desc` as any)}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--dimensions-5, 20px);
  }

  .card {
    background: var(--ss-bg);
    border: 1px solid var(--ss-border);
    border-radius: var(--radius-lg, 12px);
    padding: var(--dimensions-6, 24px);
    box-shadow: var(--shadows-card);
    transition: border-color var(--transitions-durations-medium, 300ms);
  }

  .card:hover { border-color: rgba(59, 130, 246, 0.3); }

  .icon {
    color: var(--color-primary);
    margin-bottom: var(--dimensions-4, 16px);
  }

  h3 {
    font-size: var(--text-sizes-base, 16px);
    font-weight: var(--text-weights-semibold, 600);
    color: var(--ss-text);
    margin-bottom: var(--dimensions-2, 8px);
  }

  p {
    font-size: var(--text-sizes-sm, 14px);
    color: var(--ss-muted);
    line-height: var(--text-line-heights-relaxed, 1.625);
  }

  @media (max-width: 900px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 540px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
