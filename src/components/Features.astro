---
const features = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Sin magia',
    desc: 'Sin reflexión, sin decoradores, sin generación de código. Builder patterns, interfaces y punteros. Lees el código de Keel y entiendes exactamente qué pasa.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
    title: 'OpenAPI automático',
    desc: 'La especificación OpenAPI se genera en runtime desde las definiciones de rutas. La documentación siempre está sincronizada porque es el código mismo.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>`,
    title: 'Modular por diseño',
    desc: 'Módulo → Controlador → Servicio → Repositorio. Cada capa con una responsabilidad única. Cualquier desarrollador navega el código sin necesitar un mapa.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    title: 'Listo para producción',
    desc: 'Health checks, graceful shutdown, structured logging, request ID tracking, métricas y trazabilidad con OpenTelemetry. Sin configuración extra.',
  },
]
---

<section id="features" class="section section-alt">
  <div class="container">
    <h2 class="section-title">
      Diseñado para <span class="accent-blue">proyectos reales</span>
    </h2>
    <p class="section-desc">
      No para demos. Para proyectos que van a crecer, tener más de un desarrollador
      y vivir más de seis meses.
    </p>

    <div class="grid">
      {features.map(f => (
        <div class="card">
          <div class="icon" set:html={f.icon} />
          <h3>{f.title}</h3>
          <p>{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--dimensions-5, 20px);
  }

  .card {
    background: var(--ss-bg);
    border: 1px solid var(--ss-border);
    border-radius: var(--radius-lg, 12px);
    padding: var(--dimensions-6, 24px);
    box-shadow: var(--shadows-card);
    transition: border-color var(--transitions-durations-medium, 300ms);
  }

  .card:hover { border-color: rgba(59, 130, 246, 0.3); }

  .icon {
    color: var(--color-primary);
    margin-bottom: var(--dimensions-4, 16px);
  }

  h3 {
    font-size: var(--text-sizes-base, 16px);
    font-weight: var(--text-weights-semibold, 600);
    color: var(--ss-text);
    margin-bottom: var(--dimensions-2, 8px);
  }

  p {
    font-size: var(--text-sizes-sm, 14px);
    color: var(--ss-muted);
    line-height: var(--text-line-heights-relaxed, 1.625);
  }

  @media (max-width: 900px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 540px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
