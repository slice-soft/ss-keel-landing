---
interface Props {
  title?:       string;
  description?: string;
  canonicalURL?: string;
}

const SITE = 'https://keel-go.dev'
const DEFAULT_IMAGE = 'https://cdn.slicesoft.dev/banner.png'

const {
  title = 'Keel — Framework Go para APIs REST',
  description = 'Framework Go con arquitectura modular, documentación OpenAPI automática y código explícito sin magia. Estructura real para proyectos reales.',
  canonicalURL = new URL(Astro.url.pathname, SITE).href,
} = Astro.props;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type':    'SoftwareApplication',
  name:       'Keel',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Linux, macOS, Windows',
  url:        SITE,
  description,
  author: {
    '@type': 'Organization',
    name:    'SliceSoft',
    url:     'https://slicesoft.dev',
  },
  offers: {
    '@type': 'Offer',
    price:   '0',
    priceCurrency: 'USD',
  },
})
---

<!doctype html>
<html lang="es" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="https://cdn.slicesoft.dev/marmix.ico" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content="Keel" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={DEFAULT_IMAGE} />
    <meta property="og:locale"      content="es_CO" />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={DEFAULT_IMAGE} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={jsonLd} />

    <!-- Design system tokens (SliceSoft shared) -->
    <link rel="stylesheet" href="https://cdn.slicesoft.dev/design-system/latest/css/_variables.css" />

    <!-- Anti-FOUC -->
    <script is:inline>
      ;(function () {
        var saved = localStorage.getItem('keel-theme')
        var preferred = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark'
        document.documentElement.dataset.theme = saved || preferred
      })()
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root,
  [data-theme="dark"] {
    --ss-bg:      #0d1117;
    --ss-bg-alt:  #0f1724;
    --ss-card:    #111827;
    --ss-border:  rgba(255, 255, 255, 0.07);
    --ss-text:    #f1f5f9;
    --ss-muted:   #94a3b8;
    color-scheme: dark;
  }

  [data-theme="light"] {
    --ss-bg:      #ffffff;
    --ss-bg-alt:  var(--colors-gray-50, #f8fafc);
    --ss-card:    #ffffff;
    --ss-border:  rgba(0, 0, 0, 0.08);
    --ss-text:    var(--colors-gray-900, #0f172a);
    --ss-muted:   var(--colors-gray-500, #64748b);
    color-scheme: light;
  }

  html { scroll-behavior: smooth; }

  body {
    background-color: var(--ss-bg);
    color: var(--ss-text);
    font-family: var(--text-fonts-sans, Inter, ui-sans-serif, system-ui, sans-serif);
    line-height: var(--text-line-heights-normal, 1.5);
    -webkit-font-smoothing: antialiased;
    transition:
      background-color var(--transitions-durations-medium, 300ms),
      color var(--transitions-durations-medium, 300ms);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 var(--dimensions-6, 24px);
  }

  .section {
    padding: 88px 0;
  }

  .section-alt {
    background-color: var(--ss-bg-alt);
  }

  .section-title {
    text-align: center;
    font-size: clamp(22px, 3vw, 34px);
    font-weight: var(--text-weights-bold, 700);
    letter-spacing: -0.015em;
    margin-bottom: var(--dimensions-4, 16px);
  }

  .section-desc {
    text-align: center;
    color: var(--ss-muted);
    font-size: var(--text-sizes-sm, 14px);
    max-width: 560px;
    margin: 0 auto var(--dimensions-12, 48px);
    line-height: var(--text-line-heights-relaxed, 1.625);
  }

  .accent-blue { color: var(--color-primary); }
  .accent-cyan { color: var(--color-accent); }
</style>
